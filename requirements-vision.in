# Vision and AI Dependencies (Optional)
# This file contains dependencies for OCR, computer vision, and AI vision features
# Use: pip-compile requirements-vision.in to generate requirements-vision.txt lockfile

# Include base dependencies
-c requirements.txt

# Phase 3 - OCR (TICKET-CLEANUP-VISION: Removed Tesseract/EasyOCR)
# Platform-native OCR engines are used instead (no external dependencies needed):
# - macOS: pyobjc-framework-Vision (already in core dependencies)
# - Windows: winsdk>=1.0.0b10 (in core dependencies)  
# - Linux: rapidocr-onnxruntime>=1.3.0 (in core dependencies)

# Phase 18 - Visual Fallback
opencv-python>=4.8.0  # Computer vision for template matching
mss>=9.0.0  # Fast screenshot capture

# Phase 22 - Vision Cognitive & AI
# Note: torch is still needed for transformers/Florence-2 in OmniParser
torch>=2.0.0  # PyTorch for neural models (Florence-2, transformers)
transformers>=4.35.0  # HuggingFace models (Florence-2)
sentencepiece>=0.1.99  # Required by some transformers models
accelerate>=0.24.0  # Faster model loading and inference

# TICKET-302: Florence-2 ultra-light vision support
einops>=0.7.0  # Required for vision transformer models (Florence-2)
timm>=0.9.0  # PyTorch Image Models (required by Florence-2)

# TICKET-CLEANUP-VISION: OmniParser specialized UI detection
ultralytics>=8.0.0  # YOLOv8 for UI element detection
